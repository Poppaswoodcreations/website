<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <!-- SPA Routing for IIS -->
    <rewrite>
      <rules>
        <!-- Handle SPA routes -->
        <rule name="SPA Routes" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
            <add input="{REQUEST_URI}" pattern="^/assets/" negate="true" />
            <add input="{REQUEST_URI}" pattern="^/images/" negate="true" />
            <add input="{REQUEST_URI}" pattern="\.(css|js|png|jpg|jpeg|gif|svg|ico|pdf|txt|xml)$" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
        
        <!-- Specific routes for better SEO -->
        <rule name="About Page" stopProcessing="true">
          <match url="^about/?$" />
          <action type="Rewrite" url="/index.html" />
        </rule>
        
        <rule name="Contact Page" stopProcessing="true">
          <match url="^contact/?$" />
          <action type="Rewrite" url="/index.html" />
        </rule>
        
        <rule name="Reviews Page" stopProcessing="true">
          <match url="^reviews/?$" />
          <action type="Rewrite" url="/index.html" />
        </rule>
        
        <rule name="Shipping Page" stopProcessing="true">
          <match url="^shipping/?$" />
          <action type="Rewrite" url="/index.html" />
        </rule>
        
        <!-- Product categories -->
        <rule name="Wooden Trains" stopProcessing="true">
          <match url="^wooden-trains/?$" />
          <action type="Rewrite" url="/index.html" />
        </rule>
        
        <rule name="Wooden Baby Toys" stopProcessing="true">
          <match url="^wooden-baby-toys/?$" />
          <action type="Rewrite" url="/index.html" />
        </rule>
        
        <rule name="Wooden Trucks" stopProcessing="true">
          <match url="^wooden-trucks/?$" />
          <action type="Rewrite" url="/index.html" />
        </rule>
        
        <rule name="Wooden Cars" stopProcessing="true">
          <match url="^wooden-cars/?$" />
          <action type="Rewrite" url="/index.html" />
        </rule>
        
        <rule name="Wooden Planes Helicopters" stopProcessing="true">
          <match url="^wooden-planes-helicopters/?$" />
          <action type="Rewrite" url="/index.html" />
        </rule>
        
        <rule name="Wooden Kitchenware" stopProcessing="true">
          <match url="^wooden-kitchenware/?$" />
          <action type="Rewrite" url="/index.html" />
        </rule>
        
        <rule name="Wooden Tractors Boats" stopProcessing="true">
          <match url="^wooden-tractors-boats/?$" />
          <action type="Rewrite" url="/index.html" />
        </rule>
        
        <rule name="Wooden Other Toys" stopProcessing="true">
          <match url="^wooden-other-toys/?$" />
          <action type="Rewrite" url="/index.html" />
        </rule>
        
        <!-- Product pages -->
        <rule name="Product Pages" stopProcessing="true">
          <match url="^products/(.*)$" />
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>
    
    <!-- Security Headers -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Frame-Options" value="DENY" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains; preload" />
        <add name="Content-Security-Policy" value="default-src 'self' https:; img-src 'self' data: https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; style-src 'self' 'unsafe-inline' https:; font-src 'self' data: https:; connect-src 'self' https:;" />
      </customHeaders>
    </httpProtocol>
    
    <!-- Static file caching -->
    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
    </staticContent>
    
    <!-- MIME types -->
    <staticContent>
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <mimeMap fileExtension=".woff" mimeType="font/woff" />
      <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
    </staticContent>
  </system.webServer>
</configuration>